      Use rainbow: true
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /n3mapping/synthetic/relocalization_markers
      Name: Relocalization Markers
      Namespaces:
        synthetic_pose_after: true
        synthetic_pose_before: true
        synthetic_pose_gt: true
        synthetic_relocalization_error_lines: true
        synthetic_relocalization_status: true
        synthetic_relocalization_text: true
      Queue Size: 100
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
